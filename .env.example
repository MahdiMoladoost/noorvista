# NoorVista environment example
# Copy this file to .env only on the target environment.
# Keep all real credentials in the environment/Secret Manager; never commit them.

PORT=3000
NODE_ENV=production
# پارس‌پک پشت reverse proxy اجرا می‌شود؛ برای express-rate-limit و IP واقعی لازم است.
TRUST_PROXY=1
# فقط در محیط توسعه/آزمایش؛ حساب‌های seed را هنگام شروع سرور در لاگ نمایش می‌دهد.
SHOW_TEST_ACCOUNTS_ON_STARTUP=false
# مسیر فایل محلی حساب‌های آزمایشی؛ این فایل در release و production استفاده نمی‌شود.
TEST_ACCOUNTS_FILE=.env.test-accounts

DB_HOST=<mysql-host-from-parspack>
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=db-noorvista
DB_POOL_SIZE=10
# حداکثر زمان برقراری و دریافت اتصال دیتابیس بر حسب میلی‌ثانیه
DB_CONNECT_TIMEOUT_MS=8000
DB_ACQUIRE_TIMEOUT_MS=8000

JWT_SECRET=
JWT_EXPIRES_IN=15m
COOKIE_SECRET=
SESSION_SECRET=
# High-entropy pepper used to hash OTP codes; keep distinct from all other secrets.
OTP_PEPPER=
CORS_ORIGIN=https://app-nodejs-zwcgl.<location>.abrhpaas.com

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

AI_API_KEY=
AI_BASE_URL=
AI_MODEL=
AI_ENABLED=false

SMS_API_KEY=
SMS_SENDER=
SMS_ENABLED=false

NESHAN_API_KEY=

UPLOAD_DIR=public/uploads
MAX_UPLOAD_SIZE_MB=10
# نشانی عمومی سامانه؛ در محیط عملیاتی باید HTTPS و بدون اسلش پایانی باشد.
PUBLIC_BASE_URL=https://app-nodejs-zwcgl.<location>.abrhpaas.com
APP_BASE_URL=https://app-nodejs-zwcgl.<location>.abrhpaas.com

# Private files must be outside public/.
PRIVATE_UPLOAD_DIR=./var/private-uploads
# 32-byte base64 (or 64-character hex) key. Keep in Secret Manager and rotate with a re-encryption plan.
PRIVATE_FILE_ENCRYPTION_KEY=
MALWARE_SCAN_REQUIRED=true
CLAMDSCAN_PATH=/usr/bin/clamdscan


# Clinic-local date/time policy. Store timestamps in UTC and render/validate clinic schedules in this IANA timezone.
CLINIC_TIMEZONE=Asia/Tehran

# Staff MFA (TOTP). Production requires MFA for privileged/staff roles.
# 32-byte base64 (or 64-character hex) key, distinct from all other encryption keys.
MFA_ENCRYPTION_KEY=
# High-entropy pepper used only for recovery-code hashes.
MFA_RECOVERY_PEPPER=
# Keep true in staging/production; may be false only for isolated local development.
MFA_REQUIRED_FOR_STAFF=true

# Database backup envelope encryption. Must be distinct from private-file and MFA keys.
# 32-byte base64 (or 64-character hex) key stored in Secret Manager.
BACKUP_ENCRYPTION_KEY=

# SMS outbox worker. Run a separate supervised process for each environment.
SMS_OUTBOX_POLL_MS=5000
SMS_OUTBOX_BATCH_SIZE=20
SMS_OUTBOX_MAX_ATTEMPTS=8
SMS_OUTBOX_STALE_MINUTES=10

PUBLIC_FORM_RATE_LIMIT_WINDOW_MS=900000
PUBLIC_FORM_RATE_LIMIT_MAX=5

REQUEST_BODY_LIMIT=1mb

# Optional on Windows when mysqldump is not available in PATH.
MYSQLDUMP_PATH=mysqldump
BACKUP_TIMEOUT_MS=300000

# پرداخت امن نوبت
# در محیط توسعه: sandbox | در محیط عملیاتی: zarinpal
PAYMENT_PROVIDER=sandbox
# کد پذیرنده واقعی فقط در Secret Manager یا فایل .env سرور قرار گیرد.
ZARINPAL_MERCHANT_ID=
PAYMENT_HOLD_MINUTES=10
PAYMENT_GATEWAY_TIMEOUT_MS=15000
# شبیه‌ساز فقط در توسعه فعال باشد. در محیط عملیاتی false بماند.
TEST_PAYMENT_ENABLED=false

# ارسال خودکار صف پیامک در همان فرایند وب. در استقرارهای بزرگ می‌توان false کرد و worker:sms را جدا اجرا نمود.
SMS_OUTBOX_IN_PROCESS=true
SMS_OUTBOX_INTERVAL_MS=10000
# حداکثر زمان انتظار پاسخ پنل پیامک برای ارسال فوری (میلی‌ثانیه)
SMS_GATEWAY_TIMEOUT_MS=10000

# Database maintenance from the system-admin panel. Keep disabled by default.
ALLOW_DATABASE_RESET=false
# A second explicit opt-in is required when NODE_ENV=production.
ALLOW_DATABASE_RESET_IN_PRODUCTION=false

# ParsPack safe first-run DB bootstrap. Keep false/empty in normal use.
# Set true only if you intentionally want to skip automatic table creation/migrations.
SKIP_DB_BOOTSTRAP=false
DB_BOOTSTRAP_RETRIES=30
DB_BOOTSTRAP_RETRY_DELAY_MS=2000

# Optional: create the first admin user automatically on an empty database.
# Remove these after the first successful login.
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_FULL_NAME=مدیر سیستم
BOOTSTRAP_ADMIN_PHONE=
BOOTSTRAP_ADMIN_EMAIL=

# ParsPack current app origin - set these in Node.js ENV panel
CORS_ORIGIN=https://app-nodejs-s5vr7.apps.teh2.abrhapaas.com
PUBLIC_BASE_URL=https://app-nodejs-s5vr7.apps.teh2.abrhapaas.com
APP_BASE_URL=https://app-nodejs-s5vr7.apps.teh2.abrhapaas.com
