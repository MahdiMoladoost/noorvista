# NoorVista Environment Variables Example
PORT=3000
NODE_ENV=development

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=noorvista_clinic
DB_POOL_SIZE=10

JWT_SECRET=change_this_in_production
JWT_EXPIRES_IN=7d
COOKIE_SECRET=change_this_cookie_secret
SESSION_SECRET=change_this_session_secret
CORS_ORIGIN=http://localhost:3000

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Preferred source for AI/SMS settings is the settings table via admin panel.
AI_API_KEY=
AI_BASE_URL=https://api.gapgpt.app/v1
AI_MODEL=gapgpt-qwen-3.5
AI_ENABLED=false

SMS_API_KEY=
SMS_SENDER=10002000
SMS_ENABLED=false

# Upload storage
UPLOAD_DIR=public/uploads
MAX_UPLOAD_SIZE_MB=10
