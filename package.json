{
  "name": "noorvista-clinic-management",
  "version": "3.0.0-uiux-clean",
  "description": "سامانه مدیریت و نوبت‌دهی کلینیک چشم‌پزشکی NoorVista با رابط کاربری حرفه‌ای و آماده استقرار",
  "main": "server.js",
  "scripts": {
    "start": "node scripts/parspack-first-run.js && node server.js",
    "start:server": "node server.js",
    "dev": "nodemon server.js",
    "check": "node scripts/check-syntax.js",
    "migrate": "node scripts/migrate.js",
    "init-db": "node src/database/init-db.js",
    "db:bootstrap": "node scripts/parspack-first-run.js",
    "seed:services": "node scripts/seed-default-services.js",
    "worker:sms": "node scripts/workers/sms-outbox.js",
    "worker:sms:once": "node scripts/workers/sms-outbox.js --once",
    "backup:encrypt": "node scripts/backup/encrypt.js",
    "backup:decrypt": "node scripts/backup/decrypt.js",
    "tailwind:build": "tailwindcss -c tailwind.config.js -i ./src/styles/noorvista-tailwind.css -o ./public/assets/css/noorvista-tailwind.css --minify",
    "test": "npm run check"
  },
  "keywords": [
    "clinic",
    "management",
    "ophthalmology",
    "appointment",
    "medical"
  ],
  "author": "NoorVista Team",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^6.7.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "kavenegar": "^1.1.4",
    "moment-jalaali": "^0.9.2",
    "morgan": "^1.10.0",
    "mysql2": "^3.2.0",
    "nodemailer": "^9.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "tailwindcss": "^3.4.17"
  }
}
